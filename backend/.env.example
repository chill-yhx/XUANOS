XUANOS_APP_ENV=development
XUANOS_DATABASE_URL=sqlite:///./data/xuanos_dev.db
XUANOS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
XUANOS_LOG_LEVEL=INFO
XUANOS_DEMO_RESET_ENABLED=false
XUANOS_SESSION_TTL_DAYS=30
XUANOS_SESSION_COOKIE_NAME=xuanos_session
XUANOS_SMS_PROVIDER=fake
XUANOS_FAKE_SMS_OUTBOX_PATH=data/fake_sms_outbox.jsonl
XUANOS_SMS_CODE_HMAC_KEY=
XUANOS_SMS_CODE_TTL_SECONDS=300
XUANOS_SMS_SEND_COOLDOWN_SECONDS=60
XUANOS_SMS_PHONE_HOURLY_LIMIT=5
XUANOS_SMS_IP_HOURLY_LIMIT=30
XUANOS_SMS_CODE_MAX_ATTEMPTS=5
XUANOS_PASSWORD_MIN_LENGTH=10
XUANOS_PASSWORD_LOGIN_WINDOW_MINUTES=15
XUANOS_PASSWORD_LOGIN_PHONE_LIMIT=5
XUANOS_PASSWORD_LOGIN_IP_LIMIT=30
XUANOS_DECISION_ENGINE_PROVIDER=deterministic
XUANOS_LLM_MODEL=
XUANOS_LLM_API_KEY=
XUANOS_LLM_BASE_URL=
XUANOS_LLM_TIMEOUT_SECONDS=8
XUANOS_LLM_SHADOW_ENABLED=false
